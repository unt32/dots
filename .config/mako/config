font=monospace 12
format=<b>%a ⏵</b> %s\n%b
sort=-time
layer=overlay
anchor=top-right
background-color=#0b0b0b
text-color=#d0d0d0
width=300
height=110
margin=5
padding=5
border-size=4
border-color=#505050
border-radius=8
icons=0
max-icon-size=64
default-timeout=60000
ignore-timeout=1

[urgency=low]
border-color=#505050

[urgency=normal]
border-color=#7fc8ff

[urgency=high]
border-color=#ff5555
default-timeout=0

[summary~="log-.*"]
border-color=#50fa7b
