[Unit]
PartOf=graphical-session.target
After=graphical-session.target
Requisite=graphical-session.target

[Service]
ExecStart=/usr/bin/swayidle -w timeout 290 'niri msg action power-off-monitors' timeout 300 swaylock timeout 600 'systemctl suspend-then-hibernate' resume 'niri msg action power-on-monitors' before-sleep swaylock
Restart=on-failure
